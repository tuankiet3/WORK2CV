# Supabase project URL, safe to expose in browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase publishable key, safe to expose in browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# Prisma runtime connection for Vercel/serverless.
# Use the Supabase Supavisor transaction pooler connection string.
DATABASE_URL="postgresql://prisma.YOUR_PROJECT_REF:YOUR_PRISMA_PASSWORD@YOUR_DB_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma migration/direct connection.
# Use the Supabase Supavisor session pooler or direct connection string.
DIRECT_URL="postgresql://prisma.YOUR_PROJECT_REF:YOUR_PRISMA_PASSWORD@YOUR_DB_REGION.pooler.supabase.com:5432/postgres"

# Optional, server-only. Never expose this in client code.
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
