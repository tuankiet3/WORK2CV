# Supabase project URL, safe to expose in browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key, safe to expose in browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Prisma runtime connection for Vercel/serverless.
DATABASE_URL=

# Prisma migration/direct connection.
DIRECT_URL=

# Supabase service role key, server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter configuration for AI assistant.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
